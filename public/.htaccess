<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # ส่งไฟล์และโฟลเดอร์ที่มีอยู่จริงออกไปตามปกติ
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # React Router: ให้ทุก route กลับเข้าแอป
  RewriteRule ^ index.html [L]
</IfModule>

<IfModule mod_headers.c>
  # HTML ต้องตรวจสอบเวอร์ชันใหม่เสมอ
  <FilesMatch "\.(html)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>

  # Vite ใส่ content hash ในชื่อ asset แล้ว จึง cache ได้นาน
  <FilesMatch "\.(js|css|png|jpg|jpeg|gif|svg|webp|woff|woff2)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>
